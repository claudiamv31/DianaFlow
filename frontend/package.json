{
  "name": "shine",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.87.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.11.0",
    "bootstrap": "^5.3.8",
    "framer-motion": "^12.23.12",
    "i18next": "^23.16.8",
    "react": "^19.1.0",
    "react-bootstrap": "^2.10.10",
    "react-calendar": "^6.0.0",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^14.1.3",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.8.2",
    "react-scripts": "^5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "lint": "eslint src --ext .js,.jsx && node ../scripts/check-localization-contract.mjs",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:i18next/recommended"
    ],
    "rules": {
      "i18next/no-literal-string": [
        "error",
        {
          "mode": "jsx-text-only",
          "jsx-attributes": {
            "include": [
              "alt",
              "aria-label",
              "placeholder",
              "title"
            ]
          },
          "words": {
            "exclude": [
              "DianaFlow",
              "[0-9!-/:-@[-`{-~]+",
              "[A-Z_-]+",
              "[\\s•—“”]+",
              "(account_circle|add|block|brightness_6|calendar_today|chevron_left|chevron_right|close|edit|expand_more|language|lock_reset|logout|opacity|person_outline|photo_camera|remove|self_improvement|water_drop)"
            ]
          }
        }
      ],
      "no-restricted-syntax": [
        "error",
        {
          "selector": "JSXAttribute[name.name=/^(alt|aria-label|placeholder|title)$/] > Literal",
          "message": "Translate user-facing JSX attributes instead of using literal text."
        }
      ]
    },
    "overrides": [
      {
        "files": [
          "**/*.test.js",
          "**/*.test.jsx"
        ],
        "rules": {
          "i18next/no-literal-string": "off",
          "no-restricted-syntax": "off"
        }
      }
    ]
  },
  "jest": {
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "eslint-plugin-i18next": "^6.1.5",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19"
  }
}
